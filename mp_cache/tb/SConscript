import os
import sys
from glob import glob
from pathlib import Path
from typing import Dict, List, Set

import yaml
from rich import print
from SCons.Script import Return

Import('env')


def load_svbuild_config(tb_root: Path) -> Dict:
    svbuild_path = os.path.join(tb_root, "svbuild.yaml")
    try:
        with open(svbuild_path, "r", encoding="utf-8") as f:
            config = yaml.safe_load(f) or {}
    except Exception as e:
        print(
            f"[bold red][TB] ERROR:[/bold red] "
            f"Failed to parse [cyan]{svbuild_path}[/cyan]: {e}"
        )
        sys.exit(1)
    return config


def load_testbench_config(tb_root: Path, sim_tb: str) -> Dict[str, any]:
    config = load_svbuild_config(tb_root)

    if sim_tb not in config:
        print(
            f"[bold red][TB] ERROR:[/bold red] "
            f"No testbench configuration found for '{sim_tb}' in {tb_root}/svbuild.yaml"
        )
        print(f"[bold yellow][AVAILABLE TESTBENCHES][/bold yellow] {', '.join(config.keys())}")
        sys.exit(1)

    tb_config = config[sim_tb]
    if not isinstance(tb_config, dict):
        print(
            f"[bold red][TB] ERROR:[/bold red] "
            f"'{sim_tb}' key in svbuild.yaml must be a dictionary"
        )
        sys.exit(1)

    tb_top = tb_config.get("tb_top")
    source_dirs = tb_config.get("source_dirs")
    compile_first = tb_config.get("compile_first", [])
    include_files = tb_config.get("include_files", [])

    if tb_top is None:
        print(
            f"[bold red][TB] ERROR:[/bold red] "
            f"'tb_top' is required for testbench '{sim_tb}'"
        )
        sys.exit(1)

    if not isinstance(compile_first, list):
        print(
            f"[bold red][TB] ERROR:[/bold red] "
            f"'compile_first' in '{sim_tb}' must be a list"
        )
        sys.exit(1)

    if not isinstance(include_files, list):
        print(
            f"[bold red][TB] ERROR:[/bold red] "
            f"'include_files' in '{sim_tb}' must be a list"
        )
        sys.exit(1)

    if source_dirs is not None:
        if isinstance(source_dirs, str):
            source_dirs = [source_dirs]
        elif not isinstance(source_dirs, list):
            print(
                f"[bold red][TB] ERROR:[/bold red] "
                f"'source_dirs' in '{sim_tb}' must be a string or list of strings"
            )
            sys.exit(1)

    return {
        "source_dirs": source_dirs,
        "compile_first": compile_first,
        "include_files": include_files,
        "tb_top": tb_top
    }


def collect_sv_files(tb_root: Path, source_dirs: List[str]) -> List[str]:
    if source_dirs is None:
        return glob(os.path.join(tb_root, "**/*.sv"), recursive=True)

    sv_files = []
    for scope_path in source_dirs:
        full_scope_path = os.path.join(tb_root, scope_path)

        if not os.path.exists(full_scope_path):
            print(
                f"[bold yellow][TB] WARNING:[/bold yellow] "
                f"Scope path [cyan]{scope_path}[/cyan] not found under TB_ROOT"
            )
            continue

        if os.path.isdir(full_scope_path):
            scope_files = glob(os.path.join(full_scope_path, "**/*.sv"), recursive=True)
            sv_files.extend(scope_files)
        else:
            print(
                f"[bold yellow][TB] WARNING:[/bold yellow] "
                f"Scope path [cyan]{scope_path}[/cyan] is not a directory"
            )

    return sv_files


def process_includes_and_top(
    tb_root: Path,
    tb_top: str,
    include_files: List[str]
) -> tuple[Set[str], Set[str]]:
    files_to_exclude = set()
    include_dirs = set()

    if tb_top:
        tb_top_abs = os.path.abspath(os.path.join(tb_root, tb_top))
        files_to_exclude.add(tb_top_abs)
        tb_top_dir = os.path.dirname(tb_top_abs)
        include_dirs.add(tb_top_dir)

    for include_file in include_files:
        full_include_path = os.path.join(tb_root, include_file)

        if not os.path.exists(full_include_path):
            print(
                f"[bold yellow][TB] WARNING:[/bold yellow] "
                f"Include file [cyan]{include_file}[/cyan] not found under TB_ROOT"
            )
            continue

        if os.path.isdir(full_include_path):
            print(
                f"[bold red][TB] ERROR:[/bold red] "
                f"Include path [cyan]{include_file}[/cyan] is a directory, expected a file"
            )
            sys.exit(1)

        abs_include_file = os.path.abspath(full_include_path)
        files_to_exclude.add(abs_include_file)

        parent_dir = os.path.dirname(abs_include_file)
        include_dirs.add(parent_dir)

    return files_to_exclude, include_dirs


def collect_testbench_sources(tb_root: Path, sim_tb: str) -> Dict[str, any]:
    build_config = load_testbench_config(tb_root, sim_tb)
    source_dirs = build_config["source_dirs"]
    compile_first = build_config["compile_first"]
    include_files = build_config["include_files"]
    tb_top = build_config["tb_top"]

    unordered_sources = collect_sv_files(tb_root, source_dirs)

    files_to_exclude, include_dirs = process_includes_and_top(
        tb_root, tb_top, include_files
    )

    tb_top_abs = os.path.abspath(os.path.join(tb_root, tb_top)) if tb_top else None

    tb_sources = []

    for rel_path in compile_first:
        abs_path = os.path.join(tb_root, rel_path)
        if abs_path in unordered_sources:
            tb_sources.append(abs_path)
            unordered_sources.remove(abs_path)
        else:
            print(
                f"[bold yellow][TB] WARNING:[/bold yellow] "
                f"Configured file [cyan]{rel_path}[/cyan] not found under TB_ROOT"
            )

    for source_file in unordered_sources:
        if source_file not in files_to_exclude:
            tb_sources.append(source_file)

    return {
        "sources": tb_sources,
        "include_dirs": sorted(list(include_dirs)),
        "tb_top": tb_top_abs,
    }


def build_testbench_registry(tb_root: Path) -> tuple[List[str], Dict[str, str]]:
    config = load_svbuild_config(tb_root)
    all_testbenches = list(config.keys()) if config else []

    tb_name_to_file = {}
    for tb_name in all_testbenches:
        tb_config = config.get(tb_name, {})
        tb_top = tb_config.get("tb_top")
        if tb_top:
            tb_name_to_file[tb_name] = os.path.abspath(os.path.join(tb_root, tb_top))

    return all_testbenches, tb_name_to_file


all_testbenches, tb_name_to_file = build_testbench_registry(env["TB_ROOT"])
tb_collection = collect_testbench_sources(env["TB_ROOT"], env["SIM_CFG"]["tb_name"])
tb_sources = {
    "sources": tb_collection["sources"],
    "include_dirs": tb_collection["include_dirs"],
    "tb_top": tb_collection["tb_top"],
    "testbenches": all_testbenches,
    "tb_name_to_file": tb_name_to_file,
}

Return('tb_sources')
